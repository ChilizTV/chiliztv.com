# MediaMTX VPS — environment file
# Copy to .env on the VPS (`cp .env.example .env`) and fill in the secret.
# The same secret value MUST be configured on the Render backend service under
# the env var name MEDIAMTX_PUBLISH_SECRET — auth fails 403 otherwise.
#
# Generate a fresh secret with:
#   openssl rand -base64 32

MEDIAMTX_PUBLISH_SECRET=changeme-openssl-rand-base64-32
